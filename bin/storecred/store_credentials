#!/usr/bin/env bash

echo -n "write(1) or read(2): "
read option

if [[ $option -eq 1 ]]; then
  echo -n "name of credential: "
  read cred_name

  echo -n "paste the credential: "
  read cred

  credential="$cred_name:$cred"

  cd ~/bin/storecred
  echo $credential>> credentials
else 
  cd ~/bin/storecred
  bat< credentials
fi
